# DoxAgent local environment template.
#
# Phase 0 defaults are mock-first. Do not enable real external services unless a
# later phase explicitly wires the corresponding client.

# Model provider credentials. agent_runner defaults to DashScope Bailian.
DASHSCOPE_API_KEY=
DASHSCOPE_BASE_URL=https://dashscope.aliyuncs.com/api/v2/apps/protocols/compatible-mode/v1
DASHSCOPE_MODEL=qwen3.6-flash
DASHSCOPE_ENABLE_THINKING=true
OPENAI_API_KEY=
ANTHROPIC_API_KEY=

# LangSmith tracing is off by default in Phase 0.
LANGSMITH_TRACING=false
LANGSMITH_ENDPOINT=https://api.smith.langchain.com
LANGSMITH_API_KEY=
LANGSMITH_PROJECT=doxagent-local

# DoxAtlas is represented by fixtures/mocks by default.
DOXATLAS_MODE=mock
DOXATLAS_API_BASE_URL=
DOXATLAS_API_KEY=
DOXATLAS_TOOL_BASE_URL=
DOXATLAS_TOOL_SERVER_TOKEN=

# Real tool/provider keys remain opt-in. Leave blank for mock-first local tests.
MARKET_DATA_MODE=mock
FACT_CHECK_MODE=mock
FRED_API_KEY=
BLS_API_KEY=
BEA_API_KEY=
ALPHA_VANTAGE_API_KEY=
TWELVEDATA_API_KEY=
FMP_API_KEY=
FINNHUB_API_KEY=
TAVILY_API_KEY=
ANYSEARCH_API_KEY=
SEC_USER_AGENT=DoxAgent/0.1 contact@example.com
SEC_MIN_REQUEST_INTERVAL_SECONDS=0.12
FRED_MIN_REQUEST_INTERVAL_SECONDS=0.55

# Conservative local defaults for free-tier tools.
DOXAGENT_TOOL_HTTP_TIMEOUT_SECONDS=15
FINNHUB_MAX_STREAM_SECONDS=10
FINNHUB_MAX_STREAM_EVENTS=100

# Storage defaults to in-memory. Use a URL-encoded Postgres connection string
# for Supabase direct connections when explicitly enabling persistence.
DOXAGENT_STORAGE_MODE=memory
DOXAGENT_DATABASE_URL=
