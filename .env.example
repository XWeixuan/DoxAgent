# DoxAgent local environment template.
#
# Phase 0 defaults are mock-first. Do not enable real external services unless a
# later phase explicitly wires the corresponding client.

# Model provider credentials reserved for Model Gateway work in later phases.
OPENAI_API_KEY=
ANTHROPIC_API_KEY=

# LangSmith tracing is off by default in Phase 0.
LANGSMITH_TRACING=false
LANGSMITH_API_KEY=
LANGSMITH_PROJECT=doxagent-local

# DoxAtlas is represented by fixtures/mocks in Phase 0.
DOXATLAS_MODE=mock
DOXATLAS_API_BASE_URL=
DOXATLAS_API_KEY=

# Market data and fact-checking integrations remain mocked in Phase 0.
MARKET_DATA_MODE=mock
FACT_CHECK_MODE=mock
