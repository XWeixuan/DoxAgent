# DoxAgent local environment template.
#
# Phase 0 defaults are mock-first. Do not enable real external services unless a
# later phase explicitly wires the corresponding client.

# Model provider credentials. agent_runner defaults to DashScope Bailian.
DASHSCOPE_API_KEY=
DASHSCOPE_FALLBACK_API_KEY=
DASHSCOPE_FALLBACK_API_KEYS=
DASHSCOPE_BASE_URL=https://dashscope.aliyuncs.com/api/v2/apps/protocols/compatible-mode/v1
DASHSCOPE_CHAT_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
DASHSCOPE_MODEL=qwen3.7-plus
DASHSCOPE_ENABLE_THINKING=true
DASHSCOPE_THINKING_BUDGET=2000
OPENAI_API_KEY=
ANTHROPIC_API_KEY=

# LangSmith tracing is off by default in Phase 0.
LANGSMITH_TRACING=false
LANGSMITH_ENDPOINT=https://api.smith.langchain.com
LANGSMITH_API_KEY=
LANGSMITH_PROJECT=doxagent-local

# DoxAtlas is represented by fixtures/mocks by default.
DOXATLAS_MODE=mock
DOXATLAS_API_BASE_URL=
DOXATLAS_API_KEY=
DOXATLAS_TOOL_BASE_URL=
DOXATLAS_TOOL_SERVER_TOKEN=

# Real tool/provider keys remain opt-in. Leave blank for mock-first local tests.
MARKET_DATA_MODE=mock
FACT_CHECK_MODE=mock
FRED_API_KEY=
BLS_API_KEY=
BEA_API_KEY=
ALPHA_VANTAGE_API_KEY=
TWELVEDATA_API_KEY=
FMP_API_KEY=
FINNHUB_API_KEY=
TAVILY_API_KEY=
ANYSEARCH_API_KEY=
SEC_USER_AGENT=DoxAgent/0.1 contact@example.com
SEC_MIN_REQUEST_INTERVAL_SECONDS=0.12
FRED_MIN_REQUEST_INTERVAL_SECONDS=0.55

# Monitoring Message Bus. Keep secrets in local .env or a secret manager, not code.
DOXAGENT_MONITORING_STORAGE_MODE=sqlite
DOXAGENT_MONITORING_SQLITE_PATH=.tmp/monitoring_message_bus.sqlite3
DOXAGENT_MONITORING_VIEWER_REFRESH_SECONDS=5
DOXAGENT_MONITORING_POLLER_SLEEP_SECONDS=15
DOXAGENT_MONITORING_REMOTE_SSH_ALIAS=doxagent-hk
DOXAGENT_MONITORING_REMOTE_PATH=/root/doxagent
DOXAGENT_MONITORING_REMOTE_TIMEOUT_SECONDS=20
BENZINGA_API_KEY=
BENZINGA_NEWS_BASE_URL=https://api.benzinga.com
STOCKTWITS_RAPIDAPI_KEY=
STOCKTWITS_RAPIDAPI_FALLBACK_KEY=
STOCKTWITS_RAPIDAPI_BASE_URL=https://stocktwits-sentiment-message-analytics-api.p.rapidapi.com
STOCKTWITS_RAPIDAPI_HOST=stocktwits-sentiment-message-analytics-api.p.rapidapi.com
STOCKTWITS_PUBLIC_BASE_URL=https://api.stocktwits.com/api/2
STOCKTWITS_PUBLIC_PATH_TEMPLATE=/streams/symbol/{symbol}.json
STOCKTWITS_USER_AGENT=Mozilla/5.0 (Windows NT 10.0; Win64; x64) AppleWebKit/537.36 (KHTML, like Gecko) Chrome/126.0.0.0 Safari/537.36
STOCKTWITS_ACCEPT_LANGUAGE=en-US,en;q=0.9
DOXAGENT_STOCKTWITS_STORAGE_MODE=sqlite
DOXAGENT_STOCKTWITS_SQLITE_PATH=.tmp/stocktwits_polling.sqlite3
DOXAGENT_STOCKTWITS_ALLOW_POSTGRES=0
DOXAGENT_STOCKTWITS_SYMBOLS=AAPL,MSFT,NVDA,TSLA,AMZN,META,GOOGL,AMD,PLTR,MU
DOXAGENT_STOCKTWITS_TARGET_CADENCE_SECONDS=300
DOXAGENT_STOCKTWITS_HOT_CADENCE_SECONDS=90
DOXAGENT_STOCKTWITS_SCHEDULER_TICK_SECONDS=30
DOXAGENT_STOCKTWITS_PAGE_SIZE=30
DOXAGENT_STOCKTWITS_MAX_PAGES_PER_CRAWL=10
DOXAGENT_STOCKTWITS_HOT_MESSAGE_THRESHOLD=80
DOXAGENT_STOCKTWITS_HOT_COOLDOWN_SUCCESSES=3
DOXAGENT_STOCKTWITS_MIN_REQUEST_INTERVAL_SECONDS=1.0
DOXAGENT_STOCKTWITS_REQUEST_TIMEOUT_SECONDS=15
DOXAGENT_STOCKTWITS_MAX_RETRIES=3
DOXAGENT_STOCKTWITS_RETRY_BASE_DELAY_SECONDS=1.0
TIKHUB_API_KEY=
TIKHUB_BASE_URL=https://api.tikhub.io
DOXAGENT_MONITORING_RSS_USER_AGENT=DoxAgent/0.1 monitoring-message-bus

# Unified runtime scheduler state.
DOXAGENT_RUNTIME_SCHEDULER_STORAGE_MODE=sqlite
DOXAGENT_RUNTIME_SCHEDULER_SQLITE_PATH=.tmp/runtime_scheduler.sqlite3
DOXAGENT_RUNTIME_SCHEDULER_LOOP_SLEEP_SECONDS=15

# Unified model usage cost audit. Runtime writes this store; Dashboard reads it.
DOXAGENT_MODEL_USAGE_STORAGE_MODE=sqlite
DOXAGENT_MODEL_USAGE_SQLITE_PATH=.tmp/model_usage.sqlite3
DOXAGENT_MODEL_PRICING_CONFIG_PATH=
DOXAGENT_MODEL_PRICING_DISCOUNT_RATE=0.45
DOXAGENT_MODEL_PRICING_CNY_USD_RATE=6.8

# Conservative local defaults for free-tier tools.
DOXAGENT_TOOL_HTTP_TIMEOUT_SECONDS=15
FINNHUB_MAX_STREAM_SECONDS=10
FINNHUB_MAX_STREAM_EVENTS=100

# Storage defaults to in-memory. Use a URL-encoded Postgres connection string
# for Supabase direct connections when explicitly enabling persistence.
DOXAGENT_STORAGE_MODE=memory
DOXAGENT_DATABASE_URL=
