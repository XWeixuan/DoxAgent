+    def _get_rapidapi_json_with_fallback(
+        self,
+        url: str,
+        *,
+        params: dict[str, object | None] | None,
+        timeout: float,
+        primary_key: str,
+    ) -> object:
+        fallback_key = self.settings.stocktwits_rapidapi_fallback_key
+        max_attempts = max(1, self.settings.stocktwits_max_retries)
+        last_error: httpx.HTTPError | None = None
+        for _ in range(max_attempts):
+            try:
+                return self._get_json(
+                    url,
+                    params=params,
+                    headers=self._rapidapi_headers(url, primary_key),
+                    timeout=timeout,
+                )
+            except httpx.HTTPError as exc:
+                last_error = exc
+        if fallback_key and fallback_key != primary_key:
+            try:
+                return self._get_json(
+                    url,
+                    params=params,
+                    headers=self._rapidapi_headers(url, fallback_key),
+                    timeout=timeout,
+                )
+            except httpx.HTTPError as exc:
+                if last_error is not None:
+                    raise exc from last_error
+                raise
+        if last_error is not None:
+            raise last_error
+        raise CollectorError("Stocktwits RapidAPI request failed without a captured error.")
+
+    def _rapidapi_headers(self, url: str, api_key: str) -> dict[str, str]:
+        host = self.settings.stocktwits_rapidapi_host or urlparse(url).netloc
+        return {
+            "X-RapidAPI-Key": api_key,
+            "X-RapidAPI-Host": host,
+            "Content-Type": "application/json",
+        }
+
 
